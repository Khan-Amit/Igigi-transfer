<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Igigi-transfer | Crypto Transfer Protocol</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #0a0e17 0%, #0f1622 100%);
            color: #eef2ff;
            line-height: 1.5;
            min-height: 100vh;
            padding: 1.5rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Header & Navigation */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 3rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .logo h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #fff, #5b8cff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .logo p {
            font-size: 0.85rem;
            color: #8d9bb0;
        }

        .nav-links {
            display: flex;
            gap: 1.5rem;
        }

        .nav-links a {
            color: #b9c3d4;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a:hover { color: #5b8cff; }

        /* Cards & Grid */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .card {
            background: rgba(18, 25, 40, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 1.5rem;
            border: 1px solid rgba(255,255,255,0.08);
            transition: transform 0.2s, border-color 0.2s;
        }

        .card:hover {
            border-color: rgba(91, 140, 255, 0.4);
            transform: translateY(-2px);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .card-header span { font-size: 1.8rem; }
        .card-header h3 { font-size: 1.3rem; font-weight: 600; }

        .address-box {
            background: #0b1018;
            padding: 0.75rem;
            border-radius: 16px;
            font-family: monospace;
            font-size: 0.85rem;
            word-break: break-all;
            margin: 1rem 0;
            border: 1px solid #253049;
        }

        /* Buttons */
        .btn {
            background: #1e2a44;
            border: none;
            color: white;
            padding: 0.6rem 1.2rem;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.9rem;
        }

        .btn-primary {
            background: #5b8cff;
            box-shadow: 0 4px 12px rgba(91, 140, 255, 0.2);
        }

        .btn-primary:hover {
            background: #3b6eff;
            transform: scale(0.98);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid #5b8cff;
        }

        /* Status */
        .status-badge {
            display: inline-block;
            background: #10b98120;
            color: #34d399;
            padding: 0.25rem 0.75rem;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: 3rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.05);
            font-size: 0.8rem;
            color: #6a7890;
        }

        @media (max-width: 640px) {
            body { padding: 1rem; }
            .header { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="logo">
            <h1>⚡ IGIGI-TRANSFER</h1>
            <p>Crypto Transfer Protocol · Real-time · THB Settlements</p>
        </div>
        <div class="nav-links">
            <a href="#">Dashboard</a>
            <a href="https://github.com/Khan-Amit/Igigi-transfer" target="_blank">GitHub</a>
        </div>
    </div>

    <!-- Balance Overview -->
    <div class="grid-2">
        <div class="card">
            <div class="card-header">
                <span>📊</span><h3>Mining Status</h3>
            </div>
            <div id="mining-stats">
                <p style="color:#b9c3d4;">Loading...</p>
            </div>
            <div class="address-box" id="addressDisplay">
                bc1qk7ajtrgplvn25600wm7gx9u5c5nk8kz9dfpcqy
            </div>
            <div style="display: flex; gap: 12px; margin-top: 12px;">
                <button class="btn btn-primary" id="refreshBalanceBtn">⟳ Refresh Balance</button>
                <button class="btn btn-outline" id="copyAddressBtn">📋 Copy Address</button>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><span>🏦</span><h3>THB Conversion</h3></div>
            <p style="margin-bottom: 12px;">Real-time BTC/THB rate & estimated value.</p>
            <div id="thb-stats">
                <span>฿ <strong id="estimatedThb">0.00</strong> THB</span>
                <span style="margin-left: 20px;">📈 <span id="btcRate">0</span> THB/BTC</span>
            </div>
            <div style="margin-top: 18px;">
                <label for="thbAmount" style="font-size:0.8rem;">Generate QR for bank transfer:</label>
                <div style="display: flex; gap: 8px; margin-top: 6px;">
                    <input type="number" id="thbAmount" placeholder="Amount in THB" style="flex:1; background:#0f1622; border:1px solid #2a3a60; border-radius: 40px; padding: 8px 16px; color: white;">
                    <button class="btn btn-primary" id="generateQrBtn">QR Code</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="grid-2">
        <div class="card">
            <div class="card-header"><span>⚙️</span><h3>Termux Quick Install</h3></div>
            <p>One‑line command for your mobile terminal:</p>
            <div class="address-box" style="font-size:0.75rem; user-select: all;">
                curl -sL https://git.io/JLkLv | bash
            </div>
            <button class="btn btn-outline" id="copyInstallCmd" style="margin-top: 12px;">Copy command</button>
        </div>
        <div class="card">
            <div class="card-header"><span>🛡️</span><h3>Secure & Compliant</h3></div>
            <p>Anonymous hashing · No personal data stored · Works with major Thai banks via PromptPay QR.</p>
            <span class="status-badge">🟢 Network active</span>
        </div>
    </div>

    <div class="footer">
        <p>Igigi-transfer — Crypto transfer protocol | <a href="https://github.com/Khan-Amit/Igigi-transfer" style="color:#5b8cff;">GitHub Repository</a> | MIT License</p>
    </div>
</div>

<script>
    // Configuration
    const BTC_ADDRESS = "bc1qk7ajtrgplvn25600wm7gx9u5c5nk8kz9dfpcqy";
    // Helper: fetch from API with fallback
    async function fetchJSON(url) {
        try {
            const res = await fetch(url);
            if (!res.ok) throw new Error();
            return await res.json();
        } catch(e) {
            console.warn("Fetch failed", url, e);
            return null;
        }
    }
    // Update dashboard
    async function updateDashboard() {
        // Update address display
        document.getElementById("addressDisplay").innerText = BTC_ADDRESS;
        // Fetch BTC balance from blockchain.com (cors-enabled)
        const balanceSat = await fetch(`https://blockchain.info/q/addressbalance/${BTC_ADDRESS}`).then(r=>r.text()).catch(()=>"0");
        const btcBalance = parseFloat(balanceSat) / 1e8;
        // Fetch BTC/THB price from coingecko
        const priceData = await fetchJSON("https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=thb");
        const btcThb = priceData?.bitcoin?.thb || 1800000;
        const estimatedThb = (btcBalance * btcThb).toFixed(2);
        document.getElementById("estimatedThb").innerText = estimatedThb;
        document.getElementById("btcRate").innerText = btcThb.toLocaleString();
        document.getElementById("mining-stats").innerHTML = `
            <p>✅ Estimated balance: <strong>${btcBalance.toFixed(8)} BTC</strong></p>
            <p>⛏️ <span id="shareCount">Connected to pool</span> · Last active: now</p>
        `;
    }
    // Generate QR for PromptPay (demo)
    function generatePromptPayQR(amountThb) {
        // PromptPay simple format: amount in satang ( THB*100 ), static merchant phone can be configured.
        // Use a demo phone (for real usage replace with your PromptPay id)
        const merchantPhone = "0812345678"; // Replace with your actual PromptPay phone number
        const payload = `0066${merchantPhone}${Math.floor(amountThb*100)}`; // dummy structure
        const qrUrl = `https://quickchart.io/qr?text=PromptPay|${merchantPhone}|${amountThb}&size=200`;
        return qrUrl;
    }
    // Event listeners
    document.getElementById("refreshBalanceBtn").onclick = () => updateDashboard();
    document.getElementById("copyAddressBtn").onclick = () => {
        navigator.clipboard.writeText(BTC_ADDRESS);
        alert("Address copied!");
    };
    document.getElementById("copyInstallCmd").onclick = () => {
        const cmd = "curl -sL https://git.io/JLkLv | bash";
        navigator.clipboard.writeText(cmd);
        alert("Install command copied!");
    };
    document.getElementById("generateQrBtn").onclick = () => {
        const amount = parseFloat(document.getElementById("thbAmount").value);
        if (isNaN(amount) || amount <= 0) {
            alert("Please enter a valid amount in THB");
            return;
        }
        const qrImgUrl = generatePromptPayQR(amount);
        // Open in new tab or show modal
        const win = window.open();
        win.document.write(`<img src="${qrImgUrl}" style="max-width:300px;"><p>Scan with your banking app to pay ${amount} THB</p>`);
    };
    // Initial load
    updateDashboard();
    // Auto-refresh every 60 seconds
    setInterval(updateDashboard, 60000);
</script>
</body>
</html>
